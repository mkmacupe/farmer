#!/usr/bin/env sh

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
if [ "$branch" != "main" ]; then
  exit 0
fi

git remote get-url origin >/dev/null 2>&1 || exit 0

echo "post-commit: pushing main to origin for Render auto-deploy..."
if git push origin HEAD:main; then
  echo "post-commit: origin/main updated."
else
  echo "post-commit: auto-push failed; local commit remains intact." >&2
fi
