# Local development defaults
POSTGRES_USER=sales
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_PORT=5432
API_PORT=8080

# Security
JWT_SECRET=replace-with-long-random-jwt-secret

# Demo mode
APP_DEMO_ENABLED=true
APP_DEMO_SEED_ON_STARTUP=true

# Frontend origins allowed by backend CORS
APP_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173

# Optional external geo/routing providers
APP_GEO_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
APP_ROUTING_OSRM_BASE_URL=https://router.project-osrm.org
APP_ROUTING_USER_AGENT=FarmSalesCourseProject/1.0
