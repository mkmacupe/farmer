@startuml
start
:Director logs in;
:Updates profile/addresses;
:Builds cart from catalog;
:Creates order (CREATED);

:Manager reviews request;
if (Approve?) then (yes)
  :Set status APPROVED;
  :Logistician selects driver;
  :Set status ASSIGNED;
  :Driver performs delivery;
  :Set status DELIVERED;
else (no)
  :Order remains CREATED for rework;
endif
stop
@enduml
