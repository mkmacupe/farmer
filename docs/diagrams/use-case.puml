@startuml
left to right direction
skinparam actorStyle awesome

actor "Director" as director
actor "Manager" as manager
actor "Logistician" as logistician
actor "Driver" as driver

rectangle "Farm Sales System" {
  usecase "Login" as UC_Login
  usecase "Manage profile and store addresses" as UC_Profile
  usecase "Browse catalog with filters" as UC_Catalog
  usecase "Create delivery request" as UC_CreateOrder
  usecase "View history and repeat order" as UC_Repeat
  usecase "Approve delivery request" as UC_Approve
  usecase "Register directors" as UC_Register
  usecase "Manage products" as UC_ManageProducts
  usecase "Assign driver to approved order" as UC_Assign
  usecase "View assigned deliveries" as UC_MyDeliveries
  usecase "Mark as delivered" as UC_Delivered
  usecase "Dashboard and reports" as UC_Reports
}

director --> UC_Login
director --> UC_Profile
director --> UC_Catalog
director --> UC_CreateOrder
director --> UC_Repeat

manager --> UC_Login
manager --> UC_Register
manager --> UC_Approve
manager --> UC_ManageProducts
manager --> UC_Reports

logistician --> UC_Login
logistician --> UC_Assign

driver --> UC_Login
driver --> UC_MyDeliveries
driver --> UC_Delivered
@enduml
