        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Йогурт 0.5 л\",\n  \"category\": \"Молочная продукция\",\n  \"description\": \"Натуральный фермерский йогурт\",\n  \"photoUrl\": \"https://example.com/yogurt.jpg\",\n  \"price\": 75,\n  \"stockQuantity\": 30\n}"
